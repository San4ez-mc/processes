# ============================
# Telegram
# ============================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ============================
# LLM провайдер
# ============================
# Вибір: anthropic | openai
LLM_PROVIDER=anthropic

# API ключ Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# API ключ OpenAI (опціонально)
OPENAI_API_KEY=your_openai_api_key_here

# Назва моделі (залежить від провайдера)
# Для Anthropic: claude-sonnet-4-5, claude-opus-4-5, claude-sonnet-4-20250514
# Для OpenAI: gpt-4o, gpt-4-turbo
LLM_MODEL=claude-sonnet-4-5

# ============================
# База даних PostgreSQL
# ============================
DATABASE_URL=postgresql://postgres:password@localhost:5432/business_agent

# ============================
# Середовище
# ============================
NODE_ENV=production

# Railway автоматично підставляє PORT
PORT=3000
